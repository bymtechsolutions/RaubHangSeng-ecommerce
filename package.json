{
  "name": "raub-hang-seng-ecommerce",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server/index.ts",
    "dev:vite": "vite --port=3000 --host=0.0.0.0",
    "server": "tsx server/index.ts",
    "start": "tsx server/index.ts --production",
    "start:prod": "node dist-server/index.js --production",
    "build": "vite build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist-server/index.js",
    "build:all": "npm run build && npm run build:server && npm run verify:build",
    "test:production": "node --import tsx --test tests/invoice.test.mjs tests/production-flow.test.mjs tests/seller-auth-migration.test.mjs tests/shipping.test.mjs",
    "verify:build": "node deploy/verify-build.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "bootstrap-icons": "^1.13.1",
    "esbuild": "^0.25.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
