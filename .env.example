# Production deployment
# Docker maps host 127.0.0.1:9999 to the container's internal PORT=3000.
PORT=3000
RHS_DATA_FILE="/app/data/store.json"
# Optional for a brand-new data volume. If omitted, the initial owner password is abcd1234.
SELLER_PASSWORD="abcd1234"
SESSION_SECRET="replace-with-at-least-32-random-characters"
